generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Goal {
  id            String  @id
  title         String  @unique
  description   String
  startDate     DateTime
  endDate       DateTime
  isCompleted   Boolean @default(false)
  tasks         Task[]
}

model Task {
  id            String  @id @default(uuid())
  title         String
  description   String?
  startDate     DateTime
  isCompleted   Boolean @default(false)
  linkedGoalId  String
  goal          Goal    @relation(fields: [linkedGoalId], references: [id], onDelete: Cascade)

  @@unique([title, linkedGoalId])
}
