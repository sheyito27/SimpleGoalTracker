{
  "compilerOptions": {
    "types": ["jest", "node"],
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "." 
  },
  "include": ["src/**/*", "tests/**/*"]
}